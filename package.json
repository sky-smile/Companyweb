{
  "name": "company-web-monorepo",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "db:migrate": "pnpm --filter company-web-server run migration:run",
    "db:revert": "pnpm --filter company-web-server run migration:revert",
    "db:seed": "pnpm --filter company-web-server run seed:auth",
    "db:migrate-and-seed": "pnpm --filter company-web-server run db:migrate-and-seed",
    "db:reset": "pnpm --filter company-web-server run db:reset"
  }
}